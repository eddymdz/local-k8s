# Copy to config/config.env and customize.
# Environment variables override these values.

# --- Cluster identity ---
# Shared secret for joining nodes. Auto-generated on the first server if unset.
# K3S_TOKEN=

# API server URL (required for agents and additional servers).
# Example: https://192.168.1.10:6443
# K3S_URL=

# Kubernetes node name (defaults to hostname).
# K3S_NODE_NAME=

# --- k3s version ---
# Leave empty for the channel default. Pin for reproducible installs.
# K3S_VERSION=v1.32.3+k3s1
K3S_CHANNEL=stable

# --- High availability ---
# Set true only on the first server when building an HA control plane.
K3S_CLUSTER_INIT=false

# --- Extra k3s flags (space-separated) ---
# Examples:
#   K3S_SERVER_FLAGS="--disable traefik --tls-san my.cluster.local"
#   K3S_AGENT_FLAGS="--node-label role=worker"
K3S_SERVER_FLAGS=
K3S_AGENT_FLAGS=

# --- kubectl ---
INSTALL_KUBECTL=true
# KUBECTL_VERSION=v1.32.3

# --- Cluster administration CLI tools ---
INSTALL_CLI_TOOLS=true
INSTALL_CLI_TOOLS_ON_AGENTS=true
INSTALL_K9S=true
INSTALL_HELM=true
INSTALL_KUSTOMIZE=true
INSTALL_STERN=true
INSTALL_KUBECTX=true
INSTALL_JQ=true
INSTALL_YQ=true
INSTALL_SHELL_COMPLETION=true
# Optional version pins:
# K9S_VERSION=v0.50.6
# HELM_VERSION=v3.17.0
# KUSTOMIZE_VERSION=v5.6.0
# STERN_VERSION=v1.33.0

# --- Networking (auto-detected on server if unset) ---
# Advertised IP/hostname for the API server. Use a LAN IP for multi-node clusters.
# K3S_NODE_IP=

# --- Host preparation (run automatically before install) ---
PREPARE_HOST=true
DISABLE_SWAP=true
PERSIST_SWAP_OFF=true
INSTALL_BASE_PACKAGES=true
CONFIGURE_FIREWALL=true
# Set true if you plan to use iSCSI volumes (e.g. Longhorn).
INSTALL_ISCSI=false

# --- Argo CD ---
# Installs Argo CD only. Application manifests live in your private GitOps repo.
INSTALL_ARGOCD=true
ARGOCD_NAMESPACE=argocd
ARGOCD_VERSION=stable
ARGOCD_SERVER_EXPOSE=nodeport
ARGOCD_SERVER_INSECURE=true
ARGOCD_NODEPORT_HTTP=30080
ARGOCD_NODEPORT_HTTPS=30443
ARGOCD_INGRESS_HOST=argocd.local
INSTALL_ARGOCD_CLI=true

# Private GitOps repository (configure after install, or before bootstrap)
# ARGOCD_GITOPS_REPO=https://github.com/YOUR_ORG/your-gitops.git
# ARGOCD_GITOPS_PATH=argocd/applications
# ARGOCD_GITOPS_BRANCH=main
# ARGOCD_GIT_USERNAME=
# ARGOCD_GIT_PASSWORD=

# Set true to auto-create a root Application (app-of-apps) during install.
# Requires ARGOCD_GITOPS_REPO and credentials above.
ARGOCD_BOOTSTRAP_GITOPS=false
